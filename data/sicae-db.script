ALTER TABLE PUBLIC.DEPARTAMENTO ALTER COLUMN ID RESTART WITH 4
CREATE MEMORY TABLE PUBLIC.EMPLEADO(ID BIGINT GENERATED BY DEFAULT AS IDENTITY(START WITH 1) NOT NULL PRIMARY KEY,ACTIVO BOOLEAN NOT NULL,CARGO VARCHAR(100),CEDULA VARCHAR(20),NOMBRE VARCHAR(100),DEPARTAMENTO_ID BIGINT,HORARIO_ID BIGINT,CONSTRAINT UK_5OC42SXUU4CT8N3DUT6AWMLLU UNIQUE(CEDULA),CONSTRAINT FK63J0PQHAMAT3SURBO50QLJCBR FOREIGN KEY(DEPARTAMENTO_ID) REFERENCES PUBLIC.DEPARTAMENTO(ID))
