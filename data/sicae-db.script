ALTER TABLE PUBLIC.HORARIO ALTER COLUMN ID RESTART WITH 4
CREATE MEMORY TABLE PUBLIC.REGISTROASISTENCIA(ID BIGINT GENERATED BY DEFAULT AS IDENTITY(START WITH 1) NOT NULL PRIMARY KEY,ESRETRASO BOOLEAN NOT NULL,ESTADO VARCHAR(40),FECHA DATE,HORAENTRADA TIME,HORASALIDA TIME,EMPLEADO_ID BIGINT,CONSTRAINT FKKGHFMO8YQX3K7LQ50C4UEQLY0 FOREIGN KEY(EMPLEADO_ID) REFERENCES PUBLIC.EMPLEADO(ID))
ALTER TABLE PUBLIC.REGISTROASISTENCIA ALTER COLUMN ID RESTART WITH 27
CREATE MEMORY TABLE PUBLIC.USUARIO(ID BIGINT GENERATED BY DEFAULT AS IDENTITY(START WITH 1) NOT NULL PRIMARY KEY,PASSWORDHASH VARCHAR(255),ROL VARCHAR(30),USERNAME VARCHAR(50),EMPLEADO_ID BIGINT,CONSTRAINT UK_471I15K6VBJ1LFSFB19GETCDI UNIQUE(USERNAME),CONSTRAINT FKJIFRPBVUJ7CTW3GAB8OYRU7JJ FOREIGN KEY(EMPLEADO_ID) REFERENCES PUBLIC.EMPLEADO(ID))
ALTER TABLE PUBLIC.USUARIO ALTER COLUMN ID RESTART WITH 1
ALTER TABLE PUBLIC.CONSULTAASISTENCIA ADD CONSTRAINT FKJGYDY9CURE2A7FQR5IEHUMV8F FOREIGN KEY(EMPLEADO_ID) REFERENCES PUBLIC.EMPLEADO(ID)
ALTER TABLE PUBLIC.EMPLEADO ADD CONSTRAINT FKJWKLB1SRTJDTHMIDF1WVXK47T FOREIGN KEY(HORARIO_ID) REFERENCES PUBLIC.HORARIO(ID)
